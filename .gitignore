## Ignore Visual Studio temporary files, build results, and
## files generated by popular IDEs.
## Ref: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
build/
bld/
[Bin]/[Debug]/
[Bin]/[Release]/
[Obj]/
[obj]/
bin/
obj/

# Visual Studio 2015/2017 cache directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
# wwwroot/lib/

# Publish output
*publish/

# Metadata SQL Server database files
*.mdf
*.ldf
*.ndf

# Backup and restore files from NuGet
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.Development.json

# Rider
.idea/
*.sln.iml
