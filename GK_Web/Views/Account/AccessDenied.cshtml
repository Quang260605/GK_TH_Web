@{
    ViewData["Title"] = "Không Có Quyền Truy Cập";
}

<div class="auth-container">
    <div class="auth-card text-center py-5">
        <div class="text-danger mb-4">
            <i class="fa fa-hand-holding-hand fa-4x text-danger-custom"></i>
        </div>
        <h2 class="fw-bold mb-3">Truy Cập Bị Từ Chối</h2>
        <p class="text-muted mb-4 px-3">
            Tài khoản của bạn không có đủ quyền hạn để truy cập vào trang này. 
            Vui lòng đăng nhập bằng tài khoản có quyền phù hợp hoặc quay lại trang chủ.
        </p>
        <div class="d-grid gap-2 col-8 mx-auto">
            <a asp-controller="Home" asp-action="Index" class="btn-primary-custom">
                <i class="fa fa-home me-2"></i> Quay về Trang Chủ
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="btn-secondary-custom w-100">
                    <i class="fa fa-right-from-bracket me-2"></i> Đăng Xuất & Đăng Nhập Lại
                </button>
            </form>
        </div>
    </div>
</div>
