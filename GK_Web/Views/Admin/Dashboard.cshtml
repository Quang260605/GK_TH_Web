@{
    ViewData["Title"] = "Bảng Thống Kê Admin";
    var recentEnrollments = ViewBag.RecentEnrollments as IEnumerable<GK_Web.Models.Enrollment>;
    var chartLabels = ViewBag.ChartLabels as string[];
    var chartData = ViewBag.ChartData as int[];
}

<div class="container py-4 animate-fade-in">
    <!-- Header -->
    <div class="mb-4">
        <h2 class="fw-bold text-primary-custom mb-1"><i class="fa fa-chart-line me-2"></i> Bảng Thống Kê Quản Trị</h2>
        <p class="text-muted">Tổng quan báo cáo hệ thống đăng ký học phần sinh viên</p>
    </div>

    <!-- Stats Grid Cards -->
    <div class="row g-4 mb-5">
        <!-- Card 1: Total Courses -->
        <div class="col-md-4">
            <div class="stat-card p-4 rounded-4 shadow-sm bg-white border border-start-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted fs-xs text-uppercase fw-bold d-block mb-1">Tổng Số Học Phần</span>
                        <h2 class="fw-bold mb-0 text-dark">@ViewBag.TotalCourses</h2>
                    </div>
                    <div class="stat-icon-wrapper bg-primary bg-opacity-10 text-primary rounded-pill p-3">
                        <i class="fa fa-book-open fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3 fs-xs text-muted">
                    <a asp-action="Index" class="text-decoration-none text-primary-custom fw-semibold">
                        Xem chi tiết <i class="fa fa-chevron-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Card 2: Total Students -->
        <div class="col-md-4">
            <div class="stat-card p-4 rounded-4 shadow-sm bg-white border border-start-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted fs-xs text-uppercase fw-bold d-block mb-1">Tổng Số Sinh Viên</span>
                        <h2 class="fw-bold mb-0 text-dark">@ViewBag.TotalStudents</h2>
                    </div>
                    <div class="stat-icon-wrapper bg-success bg-opacity-10 text-success rounded-pill p-3">
                        <i class="fa fa-users fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3 fs-xs text-muted">
                    <span>Sinh viên đăng ký tài khoản</span>
                </div>
            </div>
        </div>

        <!-- Card 3: Total Enrollments -->
        <div class="col-md-4">
            <div class="stat-card p-4 rounded-4 shadow-sm bg-white border border-start-4 border-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted fs-xs text-uppercase fw-bold d-block mb-1">Tổng Lượt Đăng Ký</span>
                        <h2 class="fw-bold mb-0 text-dark">@ViewBag.TotalEnrollments</h2>
                    </div>
                    <div class="stat-icon-wrapper bg-info bg-opacity-10 text-info rounded-pill p-3">
                        <i class="fa fa-clipboard-list fa-2x"></i>
                    </div>
                </div>
                <div class="mt-3 fs-xs text-muted">
                    <span>Lượt đăng ký học phần thành công</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart & Recent Activities Row -->
    <div class="row g-4">
        <!-- Chart Area -->
        <div class="col-lg-7">
            <div class="card rounded-4 border shadow-sm bg-white p-4 h-100">
                <h5 class="fw-bold text-dark mb-4"><i class="fa fa-chart-column me-2 text-primary-custom"></i> Số lượng đăng ký theo học phần</h5>
                
                @if (chartData == null || chartData.Length == 0 || chartData.Sum() == 0)
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                        <i class="fa fa-chart-bar fa-3x mb-3 text-muted opacity-50"></i>
                        <p class="mb-0">Chưa có dữ liệu đăng ký học phần để hiển thị biểu đồ.</p>
                    </div>
                }
                else
                {
                    <div style="position: relative; height: 320px; width: 100%;">
                        <canvas id="enrollmentChart"></canvas>
                    </div>
                }
            </div>
        </div>

        <!-- Recent Enrollments Area -->
        <div class="col-lg-5">
            <div class="card rounded-4 border shadow-sm bg-white p-4 h-100">
                <h5 class="fw-bold text-dark mb-4"><i class="fa fa-history me-2 text-primary-custom"></i> Hoạt động đăng ký gần đây</h5>
                
                @if (recentEnrollments == null || !recentEnrollments.Any())
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                        <i class="fa fa-folder-open fa-3x mb-3 text-muted opacity-50"></i>
                        <p class="mb-0">Chưa có lượt đăng ký học phần nào.</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var log in recentEnrollments)
                        {
                            <div class="list-group-item px-0 py-3 border-bottom d-flex justify-content-between align-items-start gap-2 fs-sm">
                                <div>
                                    <div class="fw-bold text-dark">@log.User?.Email</div>
                                    <div class="text-muted fs-xs">
                                        Đăng ký: <span class="text-primary-custom fw-semibold">@log.Course?.Name</span>
                                    </div>
                                </div>
                                <span class="badge bg-light text-muted border py-1.5 px-2 fw-normal fs-xxs">
                                    @log.EnrollDate.ToString("dd/MM HH:mm")
                                </span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (chartData != null && chartData.Length > 0 && chartData.Sum() > 0)
{
    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const ctx = document.getElementById('enrollmentChart').getContext('2d');
                
                // Get data from Razor ViewBag variables
                const labels = @Html.Raw(Json.Serialize(chartLabels));
                const data = @Html.Raw(Json.Serialize(chartData));

                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels.map(l => l.length > 20 ? l.substring(0, 18) + '...' : l),
                        datasets: [{
                            label: 'Lượt đăng ký',
                            data: data,
                            backgroundColor: 'rgba(79, 70, 229, 0.7)',
                            borderColor: 'rgba(79, 70, 229, 1)',
                            borderWidth: 1.5,
                            borderRadius: 6,
                            borderSkipped: false,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    title: function(context) {
                                        return labels[context[0].dataIndex];
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    stepSize: 1,
                                    color: '#64748b',
                                    font: {
                                        size: 11
                                    }
                                },
                                grid: {
                                    color: '#f1f5f9'
                                }
                            },
                            x: {
                                ticks: {
                                    color: '#64748b',
                                    font: {
                                        size: 10
                                    }
                                },
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                });
            });
        </script>
    }
}
